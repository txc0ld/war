{
  "name": "warpath",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "db:migrate": "pnpm --filter @warpath/api run db:migrate",
    "dev:web": "pnpm --filter @warpath/web dev",
    "dev:api": "pnpm --filter @warpath/api dev",
    "dev": "pnpm run --parallel dev:web dev:api",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @warpath/shared exec tsc --noEmit -p tsconfig.json && pnpm --filter @warpath/api exec tsc --noEmit -p tsconfig.json && pnpm --filter @warpath/web exec tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@warpath/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.12.8",
    "pg": "^8.13.0",
    "viem": "^2.21.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "esbuild",
      "keccak",
      "utf-8-validate"
    ]
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
