{
  "name": "@warpath/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./gunNames": {
      "types": "./dist/gunNames.d.ts",
      "import": "./dist/gunNames.js",
      "require": "./dist/gunNames.cjs"
    },
    "./stats": {
      "types": "./dist/stats.d.ts",
      "import": "./dist/stats.js",
      "require": "./dist/stats.cjs"
    },
    "./s2Types": {
      "types": "./dist/s2Types.d.ts",
      "import": "./dist/s2Types.js",
      "require": "./dist/s2Types.cjs"
    },
    "./s2Constants": {
      "types": "./dist/s2Constants.d.ts",
      "import": "./dist/s2Constants.js",
      "require": "./dist/s2Constants.cjs"
    },
    "./s2Auth": {
      "types": "./dist/s2Auth.d.ts",
      "import": "./dist/s2Auth.js",
      "require": "./dist/s2Auth.cjs"
    },
    "./s2GameTypes": {
      "types": "./dist/s2GameTypes.d.ts",
      "import": "./dist/s2GameTypes.js",
      "require": "./dist/s2GameTypes.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.declarations.json",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "viem": "^2.21.0"
  }
}
